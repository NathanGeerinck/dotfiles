#!/bin/bash
#
# Installs Claude Code and symlinks the config in this repo into ~/.claude.
# Safe to run repeatedly. Can be run standalone or from bin/install.

set -e

DOTFILES="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export DOTFILES
source "$DOTFILES/bin/lib.sh"

CLAUDE_SRC="$DOTFILES/config/claude"
CLAUDE_DIR="$HOME/.claude"

echo "Setting up Claude Code..."

[ -d "$CLAUDE_SRC" ] || abort "$CLAUDE_SRC not found, aborting"

# Install the CLI if it isn't there yet
if command -v claude >/dev/null 2>&1; then
  ok "Claude Code already installed"
elif command -v brew >/dev/null 2>&1; then
  brew install --cask claude-code
else
  curl -fsSL https://claude.ai/install.sh | bash
fi

mkdir -p "$CLAUDE_DIR"

link "$CLAUDE_SRC/CLAUDE.md" "$CLAUDE_DIR/CLAUDE.md"
link "$CLAUDE_SRC/laravel-php-guidelines.md" "$CLAUDE_DIR/laravel-php-guidelines.md"
link "$CLAUDE_SRC/settings.json" "$CLAUDE_DIR/settings.json"
link "$CLAUDE_SRC/statusline.sh" "$CLAUDE_DIR/statusline.sh"
link "$CLAUDE_SRC/skills" "$CLAUDE_DIR/skills"
link "$CLAUDE_SRC/agents" "$CLAUDE_DIR/agents"

# MCP servers cannot be symlinked. Claude Code keeps them in ~/.claude.json,
# which also holds machine specific state like startup counts and project
# history, so registering them through the CLI is what makes them reproducible.
# OAuth is still a manual step, see the readme.
if command -v claude >/dev/null 2>&1; then
  if claude mcp get ploi >/dev/null 2>&1; then
    ok "ploi MCP server already registered"
  elif claude mcp add --scope user --transport http ploi https://ploi.io/api/mcp >/dev/null 2>&1; then
    ok "ploi MCP server registered"
  else
    warn "could not register the ploi MCP server"
  fi

  # The token is kept as a ${INTILLI_MCP_TOKEN} reference (single quotes), so it
  # is not written to ~/.claude.json. Claude Code expands it at runtime from the
  # shell env, which env.zsh populates from the op-injected .env.
  if claude mcp get nodux >/dev/null 2>&1; then
    ok "nodux MCP server already registered"
  elif claude mcp add --scope user --transport http nodux https://intilli.be/backend/mcp \
      --header 'Authorization: Bearer ${INTILLI_MCP_TOKEN}' >/dev/null 2>&1; then
    ok "nodux MCP server registered"
  else
    warn "could not register the nodux MCP server"
  fi
else
  warn "claude not on PATH, skipping MCP servers"
fi

echo "Claude Code setup complete. Restart Claude Code to pick up the changes."
