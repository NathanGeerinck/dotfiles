{
  "$schema": "https://opencode.ai/config.json",
  "theme": "catppuccin",
  "autoshare": false,
  "autoupdate": true,
  "model": "anthropic/claude-sonnet-4-5-20250929",
  "mcp": {
    "browser": {
      "type": "local",
      "enabled": false,
      "command": ["npx", "@browsermcp/mcp@latest"]
    },
    "shortcut": {
      "type": "local",
      "enabled": true,
      "command": ["npx", "-y", "@shortcut/mcp@latest"],
      "environment": {
        "SHORTCUT_API_TOKEN": "{env:SHORTCUT_KEY_TNT}"
      }
    },
    "ray-app": {
      "type": "remote",
      "enabled": true,
      "url": "http://localhost:2411/mcp"
    }
  }
}
