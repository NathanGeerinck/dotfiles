cask 'iterm2'
cask 'obsidian'
cask 'phpstorm'
cask 'slack'
cask 'synology-drive'
cask 'ray'
cask 'raycast'
cask 'stremio'
cask 'spotify'
cask 'tableplus'
cask 'tower'

# Docker
