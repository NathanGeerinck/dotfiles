[user]
	name = Nathan Geerinck
	email = nathan@intilli.be
	signingkey = ssh-rsa 
[core]
	excludesfile = ~/.global-gitignore
	pager = delta

[gpg]
	format = ssh
[gpg "ssh"]
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
[commit]
	gpgsign = true
[mergetool]
	keepBackup = false
[init]
	defaultBranch = master

[push]
	# Push a new branch without the --set-upstream dance
	autoSetupRemote = true
[fetch]
	# Drop remote-tracking branches whose remote is gone
	prune = true
[merge]
	# Show the common ancestor in conflicts, not just the two sides.
	# zdiff3 over diff3: same info, but shared lines are hoisted out of the
	# conflict region instead of being duplicated in it.
	conflictstyle = zdiff3
[diff]
	# Distinguish moved code from genuinely added or removed code
	colorMoved = default

[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	light = false
	side-by-side = true
	line-numbers = true
[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
